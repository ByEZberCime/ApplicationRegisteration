<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/loading_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:animationCache="true"
    android:background="#D4D4D4"
    tools:context=".LoadingActivity">

    <ProgressBar
        android:id="@+id/laoding_progressbar"
        style="?android:attr/progressBarStyle"
        android:layout_width="42dp"
        android:layout_height="32dp"
        android:layout_marginStart="150dp"
        android:layout_marginEnd="140dp"
        android:layout_marginBottom="180dp"
        android:max="100"
        android:min="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.425"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/loadingbar_value_text"
        android:layout_width="148dp"
        android:layout_height="34dp"
        android:layout_marginTop="4dp"
        android:textColor="#000"
        android:text="0"
        android:textAlignment="center"
        android:textSize="23dp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/laoding_progressbar"
        app:layout_constraintStart_toStartOf="@+id/laoding_progressbar"
        app:layout_constraintTop_toBottomOf="@+id/laoding_progressbar" />

    <TextView
        android:id="@+id/loading_about_text4"
        android:layout_width="275dp"
        android:layout_height="58dp"
        android:layout_marginTop="28dp"
        android:text="Wait to anyalising and loading base"
        android:textAlignment="center"
        android:textSize="23dp"
        android:textColor="#AFAFAF"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/loadingbar_value_text"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="@+id/loadingbar_value_text"
        app:layout_constraintTop_toBottomOf="@+id/loadingbar_value_text" />
</androidx.constraintlayout.widget.ConstraintLayout>